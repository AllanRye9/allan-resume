# Admin password for the /admin dashboard (REQUIRED — the server returns 503 if not set)
# Change this to a strong, unique password before deploying to production!
ADMIN_PASSWORD=changeme

# Optional salt used when generating the admin session token.
# Change this to any random string for extra security.
TOKEN_SALT=your-random-salt-here

# The URL of the Vercel frontend — used to restrict CORS to your own site.
# Example: https://your-site.vercel.app
# Leave empty to allow all origins (not recommended for production).
FRONTEND_URL=https://your-vercel-app.vercel.app

# Port for the Express server. Render sets this automatically.
PORT=3000
