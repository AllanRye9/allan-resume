# ── Frontend (Vercel) ──────────────────────────────────────────────────────
# The base URL of your backend (Render) service.
# Set this in your Vercel project dashboard under Settings → Environment Variables.
# Example: https://allan-resume-backend.onrender.com
API_ENDPOINT=https://your-backend.onrender.com

# ── Backend (Render) ───────────────────────────────────────────────────────
# These variables are set in your Render service's Environment settings.
# See backend/.env.example for the full list.

# Admin password for the /admin dashboard (REQUIRED — the server returns 503 if not set)
# Change this to a strong, unique password before deploying to production!
ADMIN_PASSWORD=changeme

# Optional salt used when generating the admin session token.
# Change this to any random string for extra security.
TOKEN_SALT=your-random-salt-here
